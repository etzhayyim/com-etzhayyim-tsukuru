{
  "lexicon": 1,
  "id": "com.etzhayyim.apps.tsukuru.manufacturerRegistry.listManufacturers",
  "defs": {
    "main": {
      "type": "query",
      "description": "List manufacturers with cursor pagination. Filters by category, countryIso3, onboardingStatus, factoryType. Phase 2 implementation post-filters MST traversal; Phase 3 will move to mst-projector view for indexed queries.",
      "parameters": {
        "type": "params",
        "properties": {
          "category": { "type": "string" },
          "countryIso3": { "type": "string" },
          "onboardingStatus": {
            "type": "string",
            "enum": ["pending-review", "active", "suspended", "off-boarded"]
          },
          "factoryType": {
            "type": "string",
            "enum": ["oem", "odm", "contract", "in-house"]
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "com.etzhayyim.apps.tsukuru.manufacturerRegistry.getManufacturer#manufacturerView"
              }
            },
            "cursor": { "type": "string" },
            "total": { "type": "integer" }
          }
        }
      }
    }
  }
}
