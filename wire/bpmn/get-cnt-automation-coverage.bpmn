<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_tsukuru_get_cnt_automation_coverage" targetNamespace="https://etzhayyim.ai/bpmn/tsukuru" exporter="hand-written" exporterVersion="1.0">
  <bpmn:process id="tsukuru_get_cnt_automation_coverage" name="tsukuru get CNT automation coverage" isExecutable="true">
    <bpmn:startEvent id="Start" name="CNT coverage request"><bpmn:outgoing>Flow_Report</bpmn:outgoing></bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Report" sourceRef="Start" targetRef="Task_Report"/>
    <bpmn:serviceTask id="Task_Report" name="get CNT automation coverage">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.xrpc.invoke"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com&quot;" target="actor"/>
          <zeebe:input source="=&quot;com.etzhayyim.apps.tsukuru.cnt.getAutomationCoverage&quot;" target="nsid"/>
          <zeebe:input source="={}" target="payload"/>
          <zeebe:output source="=result" target="coverageReport"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Report</bpmn:incoming><bpmn:outgoing>Flow_Audit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_Audit" sourceRef="Task_Report" targetRef="Task_Audit"/>
    <bpmn:serviceTask id="Task_Audit" name="emit CNT coverage audit">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.audit.emit"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com:industry:isic:c&quot;" target="actor"/>
          <zeebe:input source="=&quot;cntAutomationCoverageReported&quot;" target="action"/>
          <zeebe:input source="={ bpmnProcessId: &quot;tsukuru_get_cnt_automation_coverage&quot;, coverageReport: coverageReport }" target="payload"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Audit</bpmn:incoming><bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Task_Audit" targetRef="End"/>
    <bpmn:endEvent id="End" name="done"><bpmn:incoming>Flow_End</bpmn:incoming></bpmn:endEvent>
  </bpmn:process>
</bpmn:definitions>
