<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_tsukuru_validate_cnt_run_package" targetNamespace="https://etzhayyim.ai/bpmn/tsukuru" exporter="hand-written" exporterVersion="1.0">
  <bpmn:process id="tsukuru_validate_cnt_run_package" name="tsukuru validate CNT run package" isExecutable="true">
    <bpmn:startEvent id="Start" name="CNT run validation request"><bpmn:outgoing>Flow_Validate</bpmn:outgoing></bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Validate" sourceRef="Start" targetRef="Task_Validate"/>
    <bpmn:serviceTask id="Task_Validate" name="validate CNT execution readiness">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.xrpc.invoke"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com&quot;" target="actor"/>
          <zeebe:input source="=&quot;com.etzhayyim.apps.tsukuru.cnt.validateRunPackage&quot;" target="nsid"/>
          <zeebe:input source="={ run_package: runPackage, run_id: runId, production_order_id: productionOrderId, recipe_revision: recipeRevision, product_family: productFamily, target_spool_length_m: targetSpoolLengthM, target_strength_gpa: targetStrengthGpa, target_conductivity_s_m: targetConductivitySM, target_thermal_conductivity_w_mk: targetThermalConductivityWMK, operator_did: operatorDid, equipment_overrides: equipmentOverrides }" target="payload"/>
          <zeebe:output source="=result" target="runValidation"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Validate</bpmn:incoming><bpmn:outgoing>Flow_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_Gateway" sourceRef="Task_Validate" targetRef="Gateway_Readiness"/>
    <bpmn:exclusiveGateway id="Gateway_Readiness" name="ready for execution?">
      <bpmn:incoming>Flow_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Ready</bpmn:outgoing>
      <bpmn:outgoing>Flow_Blocked</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Ready" sourceRef="Gateway_Readiness" targetRef="Task_AuditReady"/>
    <bpmn:sequenceFlow id="Flow_Blocked" sourceRef="Gateway_Readiness" targetRef="Task_AuditBlocked"/>
    <bpmn:serviceTask id="Task_AuditReady" name="emit CNT run ready audit">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.audit.emit"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com:industry:isic:c&quot;" target="actor"/>
          <zeebe:input source="=&quot;cntRunPackageReady&quot;" target="action"/>
          <zeebe:input source="={ bpmnProcessId: &quot;tsukuru_validate_cnt_run_package&quot;, runValidation: runValidation }" target="payload"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Ready</bpmn:incoming><bpmn:outgoing>Flow_EndReady</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_AuditBlocked" name="emit CNT run blocked audit">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.audit.emit"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com:industry:isic:c&quot;" target="actor"/>
          <zeebe:input source="=&quot;cntRunPackageBlocked&quot;" target="action"/>
          <zeebe:input source="={ bpmnProcessId: &quot;tsukuru_validate_cnt_run_package&quot;, runValidation: runValidation }" target="payload"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Blocked</bpmn:incoming><bpmn:outgoing>Flow_EndBlocked</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_EndReady" sourceRef="Task_AuditReady" targetRef="End"/>
    <bpmn:sequenceFlow id="Flow_EndBlocked" sourceRef="Task_AuditBlocked" targetRef="End"/>
    <bpmn:endEvent id="End" name="validated"><bpmn:incoming>Flow_EndReady</bpmn:incoming><bpmn:incoming>Flow_EndBlocked</bpmn:incoming></bpmn:endEvent>
  </bpmn:process>
</bpmn:definitions>
