<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_tsukuru_cnt_automation_plan" targetNamespace="https://etzhayyim.ai/bpmn/tsukuru" exporter="hand-written" exporterVersion="1.0">
  <bpmn:process id="tsukuru_cnt_automation_plan" name="tsukuru CNT automation plan" isExecutable="true">
    <bpmn:startEvent id="Start" name="CNT automation request"><bpmn:outgoing>Flow_Plan</bpmn:outgoing></bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Plan" sourceRef="Start" targetRef="Task_Plan"/>
    <bpmn:serviceTask id="Task_Plan" name="plan CNT process automation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.xrpc.invoke"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com&quot;" target="actor"/>
          <zeebe:input source="=&quot;com.etzhayyim.apps.tsukuru.cnt.planAutomation&quot;" target="nsid"/>
          <zeebe:input source="={ automation_id: automationId, flow_id: flowId, cell_id: cellId, production_order_id: productionOrderId, control_level: controlLevel, requirements: requirements }" target="payload"/>
          <zeebe:output source="=result" target="automationPlan"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Plan</bpmn:incoming><bpmn:outgoing>Flow_Audit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_Audit" sourceRef="Task_Plan" targetRef="Task_Audit"/>
    <bpmn:serviceTask id="Task_Audit" name="emit CNT automation audit">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.audit.emit"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com:industry:isic:c&quot;" target="actor"/>
          <zeebe:input source="=&quot;cntAutomationPlanPrepared&quot;" target="action"/>
          <zeebe:input source="={ bpmnProcessId: &quot;tsukuru_cnt_automation_plan&quot;, automationPlan: automationPlan }" target="payload"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Audit</bpmn:incoming><bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Task_Audit" targetRef="End"/>
    <bpmn:endEvent id="End" name="done"><bpmn:incoming>Flow_End</bpmn:incoming></bpmn:endEvent>
  </bpmn:process>
</bpmn:definitions>
