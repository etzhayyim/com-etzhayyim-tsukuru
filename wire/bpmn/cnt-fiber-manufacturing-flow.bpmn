<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_tsukuru_cnt_fiber_manufacturing_flow" targetNamespace="https://etzhayyim.ai/bpmn/tsukuru" exporter="hand-written" exporterVersion="1.0">
  <bpmn:process id="tsukuru_cnt_fiber_manufacturing_flow" name="tsukuru CNT fiber manufacturing flow" isExecutable="true">
    <bpmn:startEvent id="Start" name="CNT flow request"><bpmn:outgoing>Flow_Design</bpmn:outgoing></bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Design" sourceRef="Start" targetRef="Task_Design"/>
    <bpmn:serviceTask id="Task_Design" name="design CNT fiber process">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.xrpc.invoke"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com&quot;" target="actor"/>
          <zeebe:input source="=&quot;com.etzhayyim.apps.tsukuru.cnt.designManufacturingFlow&quot;" target="nsid"/>
          <zeebe:input source="={ flow_id: flowId, production_order_id: productionOrderId, product_kind: productKind, cnt_type: cntType, synthesis_method: synthesisMethod, spinning_method: spinningMethod, target_strength_gpa: targetStrengthGpa, target_conductivity_s_m: targetConductivitySM, target_thermal_conductivity_w_mk: targetThermalConductivityWMK, line_rate_m_per_min: lineRateMPerMin, design_formats: designFormats, supplier_exchange_format: supplierExchangeFormat, supplier_did: supplierDid, artifacts: artifacts, requirements: requirements, open_actor_dids: openActorDids }" target="payload"/>
          <zeebe:output source="=result" target="cntFlow"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Design</bpmn:incoming><bpmn:outgoing>Flow_Audit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_Audit" sourceRef="Task_Design" targetRef="Task_Audit"/>
    <bpmn:serviceTask id="Task_Audit" name="emit CNT flow audit">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.audit.emit"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com:industry:isic:c&quot;" target="actor"/>
          <zeebe:input source="=&quot;cntFiberManufacturingFlowDesigned&quot;" target="action"/>
          <zeebe:input source="={ bpmnProcessId: &quot;tsukuru_cnt_fiber_manufacturing_flow&quot;, flow: cntFlow }" target="payload"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Audit</bpmn:incoming><bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Task_Audit" targetRef="End"/>
    <bpmn:endEvent id="End" name="done"><bpmn:incoming>Flow_End</bpmn:incoming></bpmn:endEvent>
  </bpmn:process>
</bpmn:definitions>
