<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_tsukuru_prepare_cnt_run_package" targetNamespace="https://etzhayyim.ai/bpmn/tsukuru" exporter="hand-written" exporterVersion="1.0">
  <bpmn:process id="tsukuru_prepare_cnt_run_package" name="tsukuru prepare CNT run package" isExecutable="true">
    <bpmn:startEvent id="Start" name="CNT run package request"><bpmn:outgoing>Flow_Prepare</bpmn:outgoing></bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_Prepare" sourceRef="Start" targetRef="Task_Prepare"/>
    <bpmn:serviceTask id="Task_Prepare" name="prepare CNT MES SCADA PLC QMS run package">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.xrpc.invoke"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com&quot;" target="actor"/>
          <zeebe:input source="=&quot;com.etzhayyim.apps.tsukuru.cnt.prepareRunPackage&quot;" target="nsid"/>
          <zeebe:input source="={ run_id: runId, production_order_id: productionOrderId, recipe_revision: recipeRevision, product_family: productFamily, target_spool_length_m: targetSpoolLengthM, target_strength_gpa: targetStrengthGpa, target_conductivity_s_m: targetConductivitySM, target_thermal_conductivity_w_mk: targetThermalConductivityWMK, operator_did: operatorDid, equipment_overrides: equipmentOverrides }" target="payload"/>
          <zeebe:output source="=result" target="runPackage"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Prepare</bpmn:incoming><bpmn:outgoing>Flow_Audit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_Audit" sourceRef="Task_Prepare" targetRef="Task_Audit"/>
    <bpmn:serviceTask id="Task_Audit" name="emit CNT run package audit">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generic.audit.emit"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;did:web:tsukuru.etzhayyim.com:industry:isic:c&quot;" target="actor"/>
          <zeebe:input source="=&quot;cntRunPackagePrepared&quot;" target="action"/>
          <zeebe:input source="={ bpmnProcessId: &quot;tsukuru_prepare_cnt_run_package&quot;, runPackage: runPackage }" target="payload"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Audit</bpmn:incoming><bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Task_Audit" targetRef="End"/>
    <bpmn:endEvent id="End" name="done"><bpmn:incoming>Flow_End</bpmn:incoming></bpmn:endEvent>
  </bpmn:process>
</bpmn:definitions>
