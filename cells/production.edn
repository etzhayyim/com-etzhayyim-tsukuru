;; tsukuru 作 — production cell (langgraph, WASM runtime)
;; ADR-2605202800 · Phase 2 scaffold
{:cell/id "production"
 :cell/glyph "作"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_production"
 :cell/doc "production-order 実行: BTO (Build-to-Order) / MTO (Made-to-Order) / CTO (Configure-to-Order). factory DID へ dispatch → 進捗更新 → ship。全段 kotoba Datom に記録 (G17)."
 :cell/state-graph
 {:nodes [:create-order :dispatch-factory :track-progress :ready-to-ship]
  :entry :create-order
  :edges [[:create-order :dispatch-factory] [:dispatch-factory :track-progress]
          [:track-progress :ready-to-ship] [:ready-to-ship :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6" "G8" "G14" "G17"]
 :cell/kotoba
 {:reads [:production-order/id :production-order/buyer-did :production-order/factory-did
          :production-order/mode :production-order/spec]
  :writes [:production-order/state :progress/id :progress/order-id :progress/stage
           :progress/pct :progress/note :progress/timestamp]}}
