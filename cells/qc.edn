;; tsukuru 作 — qc cell (langgraph, WASM runtime)
;; ADR-2605202800 · Phase 2 scaffold
{:cell/id "qc"
 :cell/glyph "作"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_qc"
 :cell/doc "quality-inspection: production-order の成果物検査 → pass/fail/rework。失敗時は order を quarantine state へ。検査結果は kotoba Datom に lossless 記録 (G17)."
 :cell/state-graph
 {:nodes [:intake :inspect :verdict :record]
  :entry :intake
  :edges [[:intake :inspect] [:inspect :verdict] [:verdict :record] [:record :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G5" "G6" "G17"]
 :cell/kotoba
 {:reads [:production-order/id :production-order/state :progress/stage]
  :writes [:quality/id :quality/order-id :quality/result :quality/defects
           :quality/inspector-did :quality/timestamp]}}
